#!/bin/sh
set -eu
cd "$(dirname "$0")"

if [ -e void-packages ]; then
	git -C void-packages reset --hard >/dev/null
else
	git clone https://github.com/void-linux/void-packages.git
	ln -s void-packages/hostdir/binpkgs binpkgs
fi

for package in srcpkgs/*; do
    [ -e "void-packages/$package" ] && rm -r "void-packages/$package"
    cp -r "$package" void-packages/srcpkgs/
done

for package in "$@"; do
    void-packages/xbps-src pkg "$package"
done
