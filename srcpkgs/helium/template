pkgname=helium
version=0.12.3.1
revision=1
short_desc="Helium browser"
maintainer="diniamo <diniamo53@gmail.com>"
license="GPL-3.0-or-later"
homepage="https://helium.computer"
changelog="https://github.com/imputnet/helium-linux/releases/tag/${version}"
distfiles="https://github.com/imputnet/helium-linux/releases/download/${version}/helium-${version}-x86_64_linux.tar.xz"
checksum=6b891cb9d37e6ec395db9dc14a64c5b31d139e09abfe36d477f03581eb1ce901
archs="x86_64"
noshlibprovides=yes

do_install() {
	mkdir -p $DESTDIR/opt/helium
	cp -a * $DESTDIR/opt/helium/

	mkdir -p $DESTDIR/usr/{bin,share/{applications,icons/hicolor/256x256/apps}}
	ln -s /opt/helium/helium $DESTDIR/usr/bin/
	ln -s /opt/helium/helium.desktop $DESTDIR/usr/share/applications/
	ln -s /opt/helium/product_logo_256.png $DESTDIR/usr/share/icons/hicolor/256x256/apps/helium.png
}
