#!/bin/bash
set -eu
cd "$(dirname "$0")"

find_upstream() {
    while read remote; do
        if git remote get-url "$remote" | grep -q "github\.com[/:]void-linux/void-packages\.git"; then
            echo -n "$remote"
            return
        fi
    done < <(git remote)

    echo "Add a remote to void-packages that points to github:void-linux/void-packages"
    exit 1
}

if [ -d void-packages ]; then
    cd void-packages
    upstream="$(find_upstream)"
    git fetch "$upstream"
    git reset --hard "$upstream"/master
else
    if [ $# -gt 0 ]; then
        void_packages="$1"
    else
        echo "Pass the void-packages repository path"
        exit
    fi

    cd "$void_packages"
    upstream="$(find_upstream)"
    git fetch "$upstream"
    cd -

    git -C "$void_packages" worktree add --detach "$PWD"/void-packages "$upstream"/master
    void-packages/xbps-src binary-bootstrap
fi
